rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── ADMIN HELPER ──────────────────────────────────────────────
    // The dedicated admin account gets full read access to everything.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'admin.ecobin@gmail.com';
    }

    // ─── USERS ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow write: if request.auth != null && request.auth.uid == uid;

      match /scans/{scanId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ─── SCAN RECORDS ──────────────────────────────────────────────
    match /scanRecords/{id} {
      allow create: if request.auth != null;
      allow read:   if isAdmin()
                    || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // ─── BADGES ────────────────────────────────────────────────────
    match /badges/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ─── USER BADGES ───────────────────────────────────────────────
    match /userBadges/{id} {
      allow read:  if isAdmin()
                   || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // ─── QUIZ QUESTIONS ────────────────────────────────────────────
    match /quizQuestions/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ─── QUIZ ATTEMPTS ─────────────────────────────────────────────
    match /quizAttempts/{id} {
      allow create: if request.auth != null;
      allow read:   if isAdmin()
                    || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // ─── WASTE REPORTS ─────────────────────────────────────────────
    match /wasteReports/{id} {
      allow create: if request.auth != null;
      allow read:   if isAdmin()
                    || (request.auth != null && resource.data.userId == request.auth.uid);
      // Admin can update status
      allow update: if isAdmin();
    }

    // ─── NOTIFICATIONS (mobile) ────────────────────────────────────
    match /notifications/{id} {
      allow read:  if request.auth != null
                   && (resource.data.userId == request.auth.uid
                       || resource.data.userId == null);
      allow write: if false;
    }

    // ─── ADMIN NOTIFICATIONS ───────────────────────────────────────
    match /adminNotifications/{id} {
      allow read, write: if isAdmin();
    }

    // ─── APP CONFIG ────────────────────────────────────────────────
    match /appConfig/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
